# Docker Compose rotated log tail fixture
#
# Captured from examples/logging/compose.yml with Docker Engine 29.5.2 and
# Docker Compose 5.1.4. The fixture records logical-line behavior for
# docker-compose logs --no-color --no-log-prefix over retained rotated logs.
# Driver retention counts differ because Docker's json-file and local drivers
# use different on-disk formats, but --tail remains line-based per service.

## rotating-json --tail 5
line-count: 5
lines:
rotate-json-246 abcdefghijklmnopqrstuvwxyzabcdefghijklmnopqrstuvwxyz
rotate-json-247 abcdefghijklmnopqrstuvwxyzabcdefghijklmnopqrstuvwxyz
rotate-json-248 abcdefghijklmnopqrstuvwxyzabcdefghijklmnopqrstuvwxyz
rotate-json-249 abcdefghijklmnopqrstuvwxyzabcdefghijklmnopqrstuvwxyz
rotate-json-250 abcdefghijklmnopqrstuvwxyzabcdefghijklmnopqrstuvwxyz

